{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vibeready-telemetry",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "vibeready-telemetry-dev",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "vars": {
    "SCHEMA_VERSION": "1"
  }
}
