#include <windows.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@VIBEREADY_VERSION_TWEAK@
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@VIBEREADY_VERSION_TWEAK@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"
    BEGIN
      VALUE "CompanyName", "VibeReady\0"
      VALUE "FileDescription", "VibeReady Windows client\0"
      VALUE "FileVersion", "@PROJECT_VERSION@.@VIBEREADY_VERSION_TWEAK@\0"
      VALUE "InternalName", "VibeReady.exe\0"
      VALUE "OriginalFilename", "VibeReady.exe\0"
      VALUE "ProductName", "VibeReady\0"
      VALUE "ProductVersion", "@PROJECT_VERSION@.@VIBEREADY_VERSION_TWEAK@\0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x409, 1200
  END
END
